{
  "name": "alph0x-portfolio",
  "version": "1.0.0",
  "description": "3D FPS Portfolio - Night City Apartment",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/portfolio.spec.cjs tests/e2e/editor.spec.cjs",
    "test:e2e:full": "playwright test tests/e2e/*.spec.cjs",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:visual:update": "playwright test tests/visual --project=chromium --update-snapshots",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preflight": "npm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "three": "^0.160.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  }
}
