{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
  },
  "include": ["docs/js/**/*.ts", "tests/**/*.ts"]
}
